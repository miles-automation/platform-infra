# IEOMD - Time-locked secret delivery
ieomd.com {
	encode zstd gzip
	header /assets/* Cache-Control "public, max-age=31536000, immutable"
	reverse_proxy ieomd:8000
}

www.ieomd.com {
	redir https://ieomd.com{uri} permanent
}

# Umami - Analytics
analytics.sparkswarm.com {
	encode zstd gzip
	reverse_proxy umami:3000
}

# Matrix/Synapse - SparkSwarm ops chat
chat.sparkswarm.com {
	reverse_proxy synapse:8008
}

