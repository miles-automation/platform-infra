[Unit]
Description=Platform drift detection (image tags, container health)
After=network-online.target docker.service
Wants=network-online.target
Requires=docker.service

[Service]
Type=oneshot
User=root
WorkingDirectory=/root/platform-infra
EnvironmentFile=/root/platform-infra/.env
ExecStart=/usr/bin/env bash /root/platform-infra/scripts/drift_check.sh

[Install]
WantedBy=multi-user.target
