#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

if [[ "${1:-}" == "--dry-run" ]]; then
  exec "${SCRIPT_DIR}/platform" agent codex --dry-run
fi

exec "${SCRIPT_DIR}/platform" agent codex -- codex --sandbox danger-full-access --ask-for-approval never "$@"
